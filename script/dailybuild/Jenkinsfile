pipeline {
    agent { label 'k8s-x86-openeuler-cbs' }

    environment {
        CCB_HOME = '/home/jenkins/ccb1'
        CCB_GATEWAY_HOST = '172.16.9.179'
        CCB_GATEWAY_PORT = '30108'
    }

    stages {
        // ============================================
        // Step 1: 初始化CCB环境和参数校验
        // ============================================
        stage('初始化CCB环境和参数校验') {
            steps {
                script {
                    withCredentials([
                        string(
                            credentialsId: 'OAUTH_PWD',
                            variable: 'OAUTH_PWD'
                        )
                    ]) {
                        echo "========== 初始化 CCB =========="

                        sh """
                            mkdir -p ~/.config/cli/defaults
                            cat > ~/.config/cli/defaults/config.yaml <<ENDOFFILE
SRV_HTTP_REPOSITORIES_HOST: ${CCB_GATEWAY_HOST}
SRV_HTTP_REPOSITORIES_PORT: ${CCB_GATEWAY_PORT}
SRV_HTTP_REPOSITORIES_PROTOCOL: http://
SRV_HTTP_RESULT_HOST: ${CCB_GATEWAY_HOST}
SRV_HTTP_RESULT_PORT: ${CCB_GATEWAY_PORT}
SRV_HTTP_RESULT_PROTOCOL: http://
GATEWAY_IP: ${CCB_GATEWAY_HOST}
GATEWAY_PORT: ${CCB_GATEWAY_PORT}
ACCOUNT: eulermaker
PASSWORD: ${OAUTH_PWD}
OAUTH_TOKEN_URL: "https://omapi.osinfra.cn/oneid/oidc/token"
OAUTH_REDIRECT_URL: "http://eulermaker.openeuler.openatom.cn/oauth/"
PUBLIC_KEY_URL: "https://omapi.osinfra.cn/oneid/public/key?community=openeuler"
ENDOFFILE

                            source \$HOME/.\${SHELL##*/}rc &>/dev/null
                        """

                        sh '''
                            ccb_test=/home/jenkins/ccb1
                            rm -rf ${ccb_test}
                            mkdir -p ${ccb_test}
                            git clone https://atomgit.com/openeuler/ccb.git ${ccb_test}
                        '''

                        def check = sh(
                            script: "${CCB_HOME}/sbin/cli/ccb -h &>/dev/null",
                            returnStatus: true
                        )
                        if (check != 0) {
                            error("ccb command is bad!")
                        }
                        echo "ccb command is ok!"
                    }
                    if (!params.PROJECT_NAME) {
                        error("PROJECT_NAME 未配置！请在 Jenkins Job → 配置 → 'This project is parameterized' 中添加:\n  - PROJECT_NAME (String Parameter)\n  - BUILD_TYPE (Choice Parameter: incremental / full)")
                    }
                    if (!params.BUILD_TYPE) {
                        error("BUILD_TYPE 未配置！请在 Jenkins Job → 配置 → 'This project is parameterized' 中添加 Choice Parameter: incremental, full")
                    }
                    echo "PROJECT_NAME = ${params.PROJECT_NAME}"
                    echo "BUILD_TYPE = ${params.BUILD_TYPE}"
                }
            }
        }

        // ============================================
        // Step 2: everything 工程 + kernel_64k 构建（并行）
        // ============================================
        stage('触发everything工程构建') {
            when { expression { !params.get('SKIP_EVERYTHING', false) } }
            steps {
                script {
                    def project = "${params.PROJECT_NAME}:everything"
                    echo "========== ccb build ${project} =========="

                    // 现在返回的是 build_id 列表
                    def buildIds = triggerBuild(project: project, buildType: params.BUILD_TYPE)
                    env.BUILD_IDS_1 = buildIds.join(',')
                    echo "构建已触发, build_ids: ${env.BUILD_IDS_1}"
                }
            }
        }

        stage('等待everything & 构建kernel_64k') {
            when { expression { !params.get('SKIP_EVERYTHING', false) || !params.get('SKIP_64k', false) } }
            steps {
                script {
                    echo "========== 等待everything + 构建kernel_64k =========="
                    def branches = [:]
                    
                    if (!params.get('SKIP_EVERYTHING', false)) {
                        branches['等待everything'] = {
                            catchError(buildResult: null, stageResult: 'UNSTABLE') {
                                def buildIds = env.BUILD_IDS_1.split(',')
                                echo "========== 监控 ${params.PROJECT_NAME}:everything =========="
                                if (!waitForBuild(buildIds: buildIds, pollInterval: 10, timeoutMinutes: params.get('EVERYTHING_TIMEOUT', '480').toInteger())) {
                                    echo "⚠️ everything工程构建未成功完成，继续下一步"
                                    error("构建未成功完成")
                                }
                                echo "✅ ${params.PROJECT_NAME}:everything 构建完成"
                            }
                        }
                    }
                    
                    if (!params.get('SKIP_64k', false)) {
                        branches['构建kernel_64k'] = {
                            catchError(buildResult: null, stageResult: 'UNSTABLE') {
                                echo "========== 触发 ${params.PROJECT_NAME}-EBS-kernel_64k =========="
                                build(
                                    job: "${params.PROJECT_NAME}-EBS-kernel_64k",
                                    propagate: false,
                                    wait: true
                                )
                                echo "✅ ${params.PROJECT_NAME}-EBS-kernel_64k 已完成"
                            }
                        }
                    }
                    
                    parallel branches
                }
            }
        }

        // ============================================
        // Step 3: 触发第二个 ccb build + check_install（并行）
        // ============================================
        stage('触发epol工程 & 制作ISO镜像') {
            when { expression { !params.get('SKIP_EPOL', false) || !params.get('SKIP_ISO', false) } }
            steps {
                script {
                    def project = "${params.PROJECT_NAME}:epol"
                    echo "========== 触发 ccb build ${project} + ISO 构建 =========="

                    parallel(
                        '触发epol工程构建': {
                            if (params.get('SKIP_EPOL', false)) {
                                echo "跳过 epol 工程构建"
                            } else {
                                def buildIds = triggerBuild(project: project, buildType: params.BUILD_TYPE)
                                env.BUILD_IDS_2 = buildIds.join(',')
                                echo "${project} 构建已触发, build_ids: ${env.BUILD_IDS_2}"
                            }
                        },
                        '触发ISO构建': {
                            if (params.get('SKIP_ISO', false)) {
                                echo "跳过 ISO 镜像构建"
                            } else {
                                build(
                                    job: "${params.PROJECT_NAME}-EBS-ISO",
                                    propagate: false,
                                    wait: true
                                )
                                echo "${params.PROJECT_NAME}-EBS-ISO 已触发"
                            }
                        }
                    )
                }
            }
        }

        // ============================================
        // Step 4: 监控 epol 工程
        // ============================================
        stage('等待epol工程构建完成') {
            when { expression { !params.get('SKIP_EPOL', false) } }
            steps {
                catchError(buildResult: null, stageResult: 'UNSTABLE') {
                    script {
                        def buildIds = env.BUILD_IDS_2.split(',')
                        echo "========== 监控 ${params.PROJECT_NAME}:epol =========="
                        if (!waitForBuild(buildIds: buildIds, pollInterval: 10, timeoutMinutes: params.get('EPOL_TIMEOUT', '360').toInteger())) {
                            echo "⚠️ epol工程构建未成功完成，继续下一步"
                            error("构建未成功完成")
                        }
                        echo "✅ ${params.PROJECT_NAME}:epol 构建完成"
                    }
                }
            }
        }

        // ============================================
        // Step 5: 触发 make_iso
        // ============================================
        stage('制作其他镜像') {
            when { expression { !params.get('SKIP_OTHER', false) } }
            steps {
                script {
                    echo "========== 触发 ${params.PROJECT_NAME}-EBS-OTHER 流水线 =========="
                    build(
                        job: "${params.PROJECT_NAME}-EBS-OTHER",
                        propagate: false,
                        wait: true
                    )
                    echo "✅ ${params.PROJECT_NAME}-EBS-OTHER 已触发"
                }
            }
        }

        // ============================================
        // Step 6: 触发 openQA 测试
        // ============================================
        stage('执行openQA测试') {
            when { expression { !params.get('SKIP_TEST', false) } }
            steps {
                script {
                    echo "========== 触发 openQA 测试 =========="
                    def testPrefix = params.PROJECT_NAME.replaceFirst('openEuler-', 'openEuler_product_').replaceAll('-', '_')
                    def testJobs = [
                        "../openEuler-QA/${testPrefix}_netinst_repo",
                        "../openEuler-QA/${testPrefix}_netinst_x86_repo",
                        "../openEuler-QA/${testPrefix}_repo",
                        "../openEuler-QA/${testPrefix}_x86_repo"
                    ]
                    parallel testJobs.collectEntries { jobName ->
                        [(jobName): {
                            build(
                                job: jobName,
                                propagate: false,
                                wait: true
                            )
                            echo "${jobName} 已触发"
                        }]
                    }
                    echo "✅ openQA 测试已触发"
                }
            }
        }
    }

    post {
        always {
            script {
                echo "========== 飞书通知 =========="
                withCredentials([
                    string(credentialsId: 'FEISHU_WEBHOOK', variable: 'FEISHU_WEBHOOK')
                ]) {
                    def buildStatus = currentBuild.result ?: 'SUCCESS'
                    def statusColor = buildStatus == 'SUCCESS' ? 'green' : 'red'
                    def statusEmoji = buildStatus == 'SUCCESS' ? '✅' : '❌'
                    def duration = currentBuild.durationString.replace(' and counting', '')
                    def buildUrl = "${env.BUILD_URL}"

                    sh """
                        curl -s -X POST '${FEISHU_WEBHOOK}' \
                            -H 'Content-Type: application/json' \
                            -d '{
                                "msg_type": "interactive",
                                "card": {
                                    "header": {
                                        "title": {
                                            "tag": "plain_text",
                                            "content": "${statusEmoji} ${params.PROJECT_NAME} 日构建通知"
                                        },
                                        "template": "${statusColor}"
                                    },
                                    "elements": [
                                        {
                                            "tag": "div",
                                            "text": {
                                                "tag": "lark_md",
                                                "content": "**项目名称：**${params.PROJECT_NAME}\\n**构建类型：**${params.BUILD_TYPE}\\n**构建结果：**${statusEmoji} ${buildStatus}\\n**耗时：**${duration}\\n**构建详情：**[点击查看](${buildUrl})"
                                            }
                                        },
                                        {
                                            "tag": "hr"
                                        },
                                        {
                                            "tag": "note",
                                            "elements": [
                                                {
                                                    "tag": "plain_text",
                                                    "content": "Jenkins 日构建流水线自动通知"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }'
                    """
                }
            }
        }
    }
}

// ============================================================
// 辅助函数：触发构建，返回 build_id 列表
// ============================================================
def triggerBuild(Map args) {
    def cmd = "${CCB_HOME}/sbin/cli/ccb build os_project=${args.project} build_type=${args.buildType}"

    echo "执行: ${cmd}"
    def output = sh(script: cmd, returnStdout: true).trim()
    echo "返回: ${output}"

    def json = readJSON(text: output)
    // 获取所有 build_id（data 的所有 key）
    return json.data.keySet().toList()
}

// ============================================================
// 辅助函数：轮询等待多个构建都结束（只判断项目状态）
// ============================================================
def waitForBuild(Map args) {
    def buildIds = args.buildIds
    def pollInterval = args.pollInterval
    def timeoutMinutes = args.timeoutMinutes

    def projectStatusStop = [201, 202, 203, 205]
    def projectStatusSuccess = [201]
    def startTime = System.currentTimeMillis()
    def iteration = 0
    def timeoutMs = timeoutMinutes ? timeoutMinutes * 60 * 1000 : null

    while (true) {
        if (timeoutMs != null) {
            def elapsed = System.currentTimeMillis() - startTime
            if (elapsed > timeoutMs) {
                echo "⚠️ 监控超时 (${timeoutMinutes}min)，已等待 ${String.format('%.1f', elapsed / 1000 / 60)} 分钟"
                return false
            }
        }

        sleep(pollInterval)
        iteration++

        def allFinished = true

        for (def buildId in buildIds) {
            def output = sh(
                script: "${CCB_HOME}/sbin/cli/ccb select builds build_id=${buildId} -f status",
                returnStdout: true
            ).trim()

            try {
                def json = readJSON(text: output)

                if (!json || json.isEmpty()) {
                    allFinished = false
                    continue
                }

                json.each { item ->
                    if (!item || !item._source) {
                        allFinished = false
                        return
                    }
                    def projStatus = item._source?.status
                    if (projStatus != null && !(projStatus in projectStatusStop)) {
                        allFinished = false
                    }
                }
            } catch (Exception e) {
                allFinished = false
            }
        }

        if (allFinished) {
            def elapsed = (System.currentTimeMillis() - startTime) / 1000 / 60
            echo "所有构建结束 (耗时: ${String.format('%.1f', elapsed)} 分钟)"
            def hasFailure = false
            for (def buildId in buildIds) {
                def output = sh(
                    script: "${CCB_HOME}/sbin/cli/ccb select builds build_id=${buildId} -f status",
                    returnStdout: true
                ).trim()
                try {
                    def json = readJSON(text: output)
                    if (json) {
                        json.each { item ->
                            if (item?._source) {
                                def projStatus = item._source?.status
                                echo "build_id ${buildId}: 项目状态: ${projStatus}"
                                if (!(projStatus in projectStatusSuccess)) {
                                    hasFailure = true
                                }
                            }
                        }
                    }
                } catch (Exception e) {
                    echo "查询结果异常 (buildId: ${buildId}): ${e.message}"
                    hasFailure = true
                }
            }
            if (hasFailure) {
                echo "⚠️ 存在构建失败的项目"
                return false
            }
            return true
        }

        if (iteration % 30 == 0) {
            def elapsed = (System.currentTimeMillis() - startTime) / 1000 / 60
            echo "构建中... (已等待 ${String.format('%.1f', elapsed)} 分钟, 查询 ${iteration} 次)"
        }
    }
}