@Library('openeuler-os-build') _

pipeline {
    agent none
    stages {
        stage('check_install') {
            steps {
                script {
                    env.ISO_RESULT_check_install = build(
                        job: "check-rpm-install-dependence-${params.VERSION}-ebs",
                        propagate: false
                    ).result
                }
            }
        }
        stage('set_release_dir') {
            steps {
                script {
                    env.ISO_RESULT_set_release_dir = build(
                        job: 'openEuler-build-01-set_release_dir',
                        parameters: [
                            string(name: 'isbuild', value: params.set_release_dir),
                            string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                            string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_aarch64),
                            string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_aarch64)
                        ],
                        propagate: false
                    ).result
                }
            }
        }
        stage('make_version') {
            steps {
                script {
                    parallel(
                        "make_iso_aarch64": {
                            env.ISO_RESULT_make_iso_aarch64 = build(
                                job: 'openEuler-build-aarch64-02-make_iso',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_iso),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_aarch64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_aarch64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_iso_x86_64": {
                            env.ISO_RESULT_make_iso_x86_64 = build(
                                job: 'openEuler-build-x86_64-02-make_iso',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_iso),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_x86_64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_x86_64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_iso_everything_aarch64": {
                            env.ISO_RESULT_make_iso_everything_aarch64 = build(
                                job: 'openEuler-build-aarch64-02-make_iso_everything',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_iso_everything),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_aarch64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_aarch64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_iso_everything_x86_64": {
                            env.ISO_RESULT_make_iso_everything_x86_64 = build(
                                job: 'openEuler-build-x86_64-02-make_iso_everything',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_iso_everything),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_x86_64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_x86_64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_debug_everything_aarch64": {
                            env.ISO_RESULT_make_debug_everything_aarch64 = build(
                                job: 'openEuler-build-aarch64-02-make_debug_everything',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_debug_everything),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_aarch64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_aarch64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_debug_everything_x86_64": {
                            env.ISO_RESULT_make_debug_everything_x86_64 = build(
                                job: 'openEuler-build-x86_64-02-make_debug_everything',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_debug_everything),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_x86_64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_x86_64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_iso_everysrc_x86_64": {
                            env.ISO_RESULT_make_iso_everysrc_x86_64 = build(
                                job: 'openEuler-build-x86_64-02-make_iso_everysrc',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_iso_everysrc),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_x86_64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_x86_64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_netinst_iso_aarch64": {
                            env.ISO_RESULT_make_netinst_iso_aarch64 = build(
                                job: 'openEuler-build-aarch64-02-make_netinst_iso',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_netinst_iso),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_aarch64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_aarch64)
                                ],
                                propagate: false
                            ).result
                        },
                        "make_netinst_iso_x86_64": {
                            env.ISO_RESULT_make_netinst_iso_x86_64 = build(
                                job: 'openEuler-build-x86_64-02-make_netinst_iso',
                                parameters: [
                                    string(name: 'isbuild', value: params.make_netinst_iso),
                                    string(name: 'STANDARD_PROJECT', value: params.STANDARD_PROJECT),
                                    string(name: 'STANDARD_PROJECT_REPO', value: params.main_repo_x86_64),
                                    string(name: 'EPOL_PROJECT_REPO', value: params.epol_repo_x86_64)
                                ],
                                propagate: false
                            ).result
                        }
                    )
                }
            }
        }
    }
    post {
        always {
            script {
                node('k8s-x86-openeuler-cbs') {
                    def duration = (currentBuild.durationString ?: 'unknown').replace(' and counting', '')

                    def jobLines = ''
                    def jobOrder = [
                        'check_install',
                        'set_release_dir',
                        'make_iso_aarch64',
                        'make_iso_x86_64',
                        'make_iso_everything_aarch64',
                        'make_iso_everything_x86_64',
                        'make_debug_everything_aarch64',
                        'make_debug_everything_x86_64',
                        'make_iso_everysrc_x86_64',
                        'make_netinst_iso_aarch64',
                        'make_netinst_iso_x86_64'
                    ]
                    def hasFailure = false
                    jobOrder.each { name ->
                        def result = env."ISO_RESULT_${name}" ?: 'SKIPPED'
                        def emoji = result == 'SUCCESS' ? '✅' : (result == 'SKIPPED' ? '⬜' : '❌')
                        jobLines += "${emoji} ${name}: ${result}\n"
                        if (result != 'SUCCESS' && result != 'SKIPPED') {
                            hasFailure = true
                        }
                    }
                    def buildStatus = hasFailure ? 'FAILURE' : 'SUCCESS'

                    sendFeishu(
                        title: "${params.STANDARD_PROJECT} ISO 构建通知",
                        project: params.STANDARD_PROJECT,
                        isSuccess: (buildStatus == 'SUCCESS'),
                        statusText: buildStatus,
                        duration: duration,
                        jobLines: jobLines,
                        showButton: true,
                        note: 'Jenkins ISO 构建流水线自动通知'
                    )
                }
            }
        }
    }
}